# ============================================================
# 必須環境変数（本番起動時に server/_core/env.ts でバリデーション）
# 未設定だと `pnpm start` が起動失敗する
# ============================================================

# JWT 署名用シークレット。最低 32 文字。`openssl rand -hex 32` 等で生成
JWT_SECRET=

# OAuth クライアント識別子（Manus アプリ ID）。サーバ・クライアント両方で使用
VITE_APP_ID=

# OAuth サーバの Base URL（例: https://oauth.example.com）
OAUTH_SERVER_URL=

# ============================================================
# 推奨環境変数
# ============================================================

# 本番起動時は必ず "production" を設定すること。
# "production" 以外（未設定含む）の場合、dev admin 自動付与は発火しないが
# シークレット欠落の検出が緩くなる。
NODE_ENV=production

# サーバ待ち受けポート（既定: 3000）
PORT=3000

# アプリ用 SQLite ファイル URL（未設定なら ./data.sqlite を使用）
# 例: sqlite:./data/app.sqlite
DATABASE_URL=

# ============================================================
# 任意環境変数（外部サービス連携時のみ）
# ============================================================

# 「アプリ所有者」として通知を受け取るユーザーの openId
OWNER_OPEN_ID=

# Manus Forge API（通知送信、ストレージプロキシ）
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ============================================================
# クライアント側ビルド時環境変数（VITE_ プレフィックス必須）
# ============================================================

# 会員ポータルログイン画面の URL
VITE_OAUTH_PORTAL_URL=

# Google Maps 等の外部 API 用フロントエンド向けプロキシ
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ============================================================
# データ移行・運用補助スクリプト用（オプション）
# ============================================================

# TiDB / Manus 本番 DB から差分を取り込むとき（sync-tidb.mjs）だけ必要
# TIDB_URL=mysql://USER:PASSWORD@HOST:4000/DBNAME
